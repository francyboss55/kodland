import random

#lettere e simboli possibili
lettere_possibili =  "+-/*!&$#?=@abcdefghijklnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890"

#settare la lunghezza della password
lunghezza = int(input("quanto deve essere lunga la password?"))

#generazione variabile password
password_nuova = ""
#generazione password
for i in range(lunghezza) :
    #continuare la generazione
    password_nuova = password_nuova + random.choice(lettere_possibili)
    
#mostra la password
print(password_nuova)
